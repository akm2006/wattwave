# ──────────────────────────────────────────────────
# IoT Energy Monitor – Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Supabase (Private) ────────────────────────────
# Removed NEXT_PUBLIC_ to prevent browser exposure.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── MQTT (Private) ────────────────────────────────
# These are no longer exposed to the public bundle.
# They are fetched via a protected API after login.
MQTT_PROTOCOL=wss
MQTT_HOST=your-cluster.s1.eu.hivemq.cloud
MQTT_PORT=8884
MQTT_PATH=/mqtt
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password

# ── Dashboard Authentication ──────────────────────
# Simple password protection for the dashboard UI
DASHBOARD_PASSWORD=your_secure_password_here
