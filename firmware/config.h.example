#ifndef CONFIG_H
#define CONFIG_H

// ---------------- WIFI SETUP ----------------
// If FORCE_WIFI_PORTAL is true, the ESP32 will always open a setup portal.
// If false, it tries to connect to saved WiFi first.
#define FORCE_WIFI_PORTAL false
#define WIFI_PORTAL_NAME "WattWave-Setup"
#define WIFI_PORTAL_PASS "12345678"

// ---------------- MQTT SETUP ----------------
// Your MQTT Broker address (e.g., HiveMQ cluster URL)
#define MQTT_BROKER "your-cluster.s1.eu.hivemq.cloud"
#define MQTT_PORT 8883
#define MQTT_USERNAME "your-mqtt-username"
#define MQTT_PASSWORD "your-mqtt-password"

// ---------------- SUPABASE SETUP ----------------
// Your Supabase Project API Key and URL
#define SUPABASE_API_KEY "your-supabase-anon-key"
#define SUPABASE_BASE_URL "https://your-project.supabase.co/rest/v1/"

// ---------------- OTA SETUP ----------------
#define OTA_USER "admin"
#define OTA_PASS "admin"

#endif
